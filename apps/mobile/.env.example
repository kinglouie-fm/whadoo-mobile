# API Backend URL
# Use localhost for iOS simulator, use your machine's IP for physical devices
# Example for physical device: http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In Client ID for iOS
# Find this in GoogleService-Info.plist under the key "CLIENT_ID"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here

# Firebase Storage Bucket
# Find this in Firebase Console → Project Categories → Databases & Storage → Storage
# Format: your-project-name.appspot.com or your-project-name.firebasestorage.app
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-name.firebasestorage.app
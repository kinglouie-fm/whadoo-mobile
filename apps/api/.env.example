# API Server Configuration
PORT=3000

# Database Connection
# Uses the PostgreSQL instance from docker-compose.yml
# Change the port if you modified the Docker configuration
DATABASE_URL="postgresql://whadoo:whadoo_password@localhost:5432/whadoo_dev?schema=public"

# Admin Secret for Development
# Used for admin-level operations during development
# Change this to any secure string (not used in production)
DEV_ADMIN_SECRET=admin

# Node Environment
NODE_ENV=development

# Firebase Service Account (required for authentication)
# Path is relative to the apps/api directory
# IMPORTANT: Use absolute path if relative path doesn't work
# Example absolute path: "/Users/yourname/path/to/whadoo/apps/api/.secrets/firebase-service-account.json"
GOOGLE_APPLICATION_CREDENTIALS="./.secrets/firebase-service-account.json"
FIREBASE_SERVICE_ACCOUNT_PATH="./.secrets/firebase-service-account.json"